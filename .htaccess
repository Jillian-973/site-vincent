# ─── Réécriture d'URL (URLs propres + repli sur l'accueil) ─────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Forcer HTTPS (certificat Let's Encrypt fourni par OVH)
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Ne jamais réécrire les vrais fichiers/dossiers (assets, favicon, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # "/activite" → son propre point d'entrée (build multi-pages Vite)
  RewriteRule ^activite/?$ /activite.html [L]

  # "/a-propos" → son propre point d'entrée (build multi-pages Vite)
  RewriteRule ^a-propos/?$ /a-propos.html [L]

  # Tout le reste (/, /main, /contact, futures pages...) → page d'accueil
  RewriteRule ^ /index.html [L]
</IfModule>

# ─── Compression (réduit le poids transféré) ────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml image/svg+xml
</IfModule>

# ─── Cache navigateur ────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  # Fichiers buildés par Vite : noms hashés (ex: main-DDUsDH4z.js) → cache long
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 month"
  # HTML : jamais en cache, pour toujours servir le dernier déploiement
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|png|jpe?g|svg|webp|ico|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>

  # En-têtes de sécurité de base
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ─── Divers ──────────────────────────────────────────────────────────────────
Options -Indexes
AddDefaultCharset UTF-8
